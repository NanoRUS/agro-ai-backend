# ============================================================
# AI-Агроном Backend — пример конфигурации
# Скопируй в .env и заполни нужные значения
# ============================================================

# --- Core ---
DATABASE_URL=sqlite+aiosqlite:///./agro.db
# Production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://agro:password@localhost:5432/agro

SECRET_KEY=change-me-in-production
DEBUG=true

# --- CORS (production: укажи свой домен) ---
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# --- CV Provider (stub by default) ---
# Plant.id API или свой CV сервис
PLANT_ID_API_KEY=

# --- LLM (для персонализации скриптов видео) ---
# Оставь пустым — будет использоваться шаблонная генерация
OPENAI_API_KEY=

# --- Weather API ---
WEATHER_API_KEY=

# --- Video Pipeline ---
VIDEO_PIPELINE_URL=
VIDEO_PIPELINE_API_KEY=

# --- Billing (stub by default — всё бесплатно) ---
BILLING_SERVICE_URL=
BILLING_SERVICE_API_KEY=

# --- S3 Media Storage ---
S3_ENDPOINT=
S3_BUCKET=agro-media
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Scoring tuning ---
TOP_ISSUES_COUNT=3
MIN_SCORE_THRESHOLD=0.05
